generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ONLINE
  OFFLINE
  BUSY
  HIDDEN
}

enum ProfileVisibility {
  PUBLIC
  FRIENDS
  PRIVATE
}

enum AnimeStatus {
  WATCHING
  COMPLETED
  ON_HOLD
  DROPPED
  PLAN_TO_WATCH
}

enum MangaStatus {
  READING
  COMPLETED
  DROPPED
  PLAN_TO_READ
}

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  username         String     @unique
  password         String
  emailVerified    Boolean    @default(false)
  twoFactorEnabled Boolean    @default(false)
  twoFactorSecret  String?
  role             String     @default("USER") // USER, ADMIN
  status           UserStatus @default(OFFLINE)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  profile         Profile?
  authSessions    AuthSession[]
  notifications   Notification[]
  animeList       AnimeList[]
  mangaList       MangaList[]
  friendships     Friendship[]      @relation("UserFriendships")
  receivedFriends Friendship[]      @relation("ReceivedFriendships")
  follows         Follow[]          @relation("UserFollowing")
  followers       Follow[]          @relation("UserFollowers")
  achievements    UserAchievement[]
  badges          UserBadge[]
  reviews         Review[]
  expLogs         EXPLog[]
  ownedClubs      Club[]            @relation("ClubOwner")
  clubMemberships ClubMember[]      @relation("ClubMemberships")
  blocking        Block[]           @relation("BlockerUser")
  blockedBy       Block[]           @relation("BlockedUser")
  dailyLogins     DailyLogin[]
  spoilerSettings SpoilerSetting[]
  avatar          UserAvatar?
  ownedRooms      Room[]            @relation("RoomOwner")
}

model Profile {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id])
  displayName String?
  bio         String?   @db.Text
  avatarUrl   String?
  bannerUrl   String?
  gender      String?
  birthday    DateTime?
  location    String?
  website     String?
  socialLinks Json? // { twitter: string, discord: string, etc }

  // Anime Profile Card
  topAnimeIds     String[] // Array of MAL/AniList IDs
  topMangaIds     String[]
  favCharacterIds String[]

  // Privacy Settings
  visibility    ProfileVisibility @default(PUBLIC)
  showAnimeList Boolean           @default(true)
  showMangaList Boolean           @default(true)
  showAge       Boolean           @default(false)

  // Stats
  totalWatchHours   Float @default(0)
  totalChaptersRead Int   @default(0)
}

model AuthSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  userAgent String?
  ipAddress String?
  token     String?  @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AnimeEntry {
  id        String    @id @default(uuid())
  malId     Int       @unique
  aniId     Int?      @unique
  titleEn   String
  titleJp   String?
  titleRo   String?
  synopsis  String?   @db.Text
  type      String? // TV, Movie, OVA
  episodes  Int?
  status    String? // Finished Airing, Currently Airing
  airedFrom DateTime?
  airedTo   DateTime?
  duration  String?
  rating    String?
  score     Float?
  images    Json?
  genres    String[]
  studios   String[]

  userLists AnimeList[]
}

model AnimeList {
  id             String      @id @default(uuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  animeId        String
  anime          AnimeEntry  @relation(fields: [animeId], references: [id])
  status         AnimeStatus @default(PLAN_TO_WATCH)
  progress       Int         @default(0) // Episode count
  score          Int? // 1-10
  notes          String?     @db.Text
  startDate      DateTime?
  finishDateTime DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([userId, animeId])
}

model MangaEntry {
  id            String    @id @default(uuid())
  malId         Int       @unique
  aniId         Int?      @unique
  titleEn       String
  titleJp       String?
  titleRo       String?
  synopsis      String?   @db.Text
  chapters      Int?
  volumes       Int?
  status        String?
  publishedFrom DateTime?
  publishedTo   DateTime?
  score         Float?
  images        Json?
  genres        String[]
  authors       String[]

  userLists MangaList[]
}

model MangaList {
  id             String      @id @default(uuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  mangaId        String
  manga          MangaEntry  @relation(fields: [mangaId], references: [id])
  status         MangaStatus @default(PLAN_TO_READ)
  progress       Int         @default(0) // Chapter count
  score          Int?
  notes          String?     @db.Text
  startDate      DateTime?
  finishDateTime DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([userId, mangaId])
}

model Friendship {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("UserFriendships", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("ReceivedFriendships", fields: [receiverId], references: [id])
  status     String   @default("PENDING") // PENDING, ACCEPTED, DECLINED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([senderId, receiverId])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id])
  followingId String
  following   User     @relation("UserFollowers", fields: [followingId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  type       String
  actorId    String?
  entityType String?
  entityId   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Badge {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  imageUrl    String?
  criteria    Json?
  userBadges  UserBadge[]
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id])
  earnedAt DateTime @default(now())
}

model Achievement {
  id               String            @id @default(uuid())
  name             String            @unique
  description      String?
  expReward        Int               @default(0)
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  earnedAt      DateTime    @default(now())
}

model Review {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  entityType  String // ANIME, MANGA
  entityId    String
  scoreTotal  Int
  scoreDetail Json? // { story, art, character, etc }
  content     String   @db.Text
  hasSpoiler  Boolean  @default(false)
  isHelpful   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EXPLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  amount    Int
  createdAt DateTime @default(now())

  @@index([userId])
}

model Club {
  id          String       @id @default(uuid())
  name        String       @unique
  slug        String       @unique
  description String?      @db.Text
  avatarUrl   String?
  bannerUrl   String?
  category    String       @default("GENERAL") // ANIME, MANGA, GENERAL, COSPLAY, FANART
  isPrivate   Boolean      @default(false)
  ownerId     String
  owner       User         @relation("ClubOwner", fields: [ownerId], references: [id])
  members     ClubMember[]
  events      Event[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ClubMember {
  id       String   @id @default(uuid())
  clubId   String
  club     Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation("ClubMemberships", fields: [userId], references: [id])
  role     String   @default("MEMBER") // OWNER, ADMIN, MEMBER
  joinedAt DateTime @default(now())

  @@unique([clubId, userId])
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blocker   User     @relation("BlockerUser", fields: [blockerId], references: [id])
  blockedId String
  blocked   User     @relation("BlockedUser", fields: [blockedId], references: [id])
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model DailyLogin {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime @default(now()) @db.Date
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model SpoilerSetting {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  animeId   String   // MAL ID
  progress  Int      @default(0) // episode progress
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, animeId])
}

// ─── 3D Avatar & Room System ──────────────────────────────────────────────────

model UserAvatar {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName  String?
  vrmUrl       String?
  thumbnailUrl String?
  isPublic     Boolean  @default(true)
  pose         String?  @default("idle")
  emotion      String?  @default("neutral")
  height       Float?   @default(1.7)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model World {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  rooms     Room[]
}

model Room {
  id          String      @id @default(uuid())
  ownerId     String
  owner       User        @relation("RoomOwner", fields: [ownerId], references: [id])
  worldId     String?
  world       World?      @relation(fields: [worldId], references: [id])
  name        String
  description String?
  isPublic    Boolean     @default(false)
  maxUsers    Int         @default(10)
  theme       String?     @default("default")
  musicUrl    String?
  spawnX      Float       @default(0)
  spawnY      Float       @default(0)
  spawnZ      Float       @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  decors      RoomDecor[]
}

model RoomDecor {
  id       String  @id @default(uuid())
  roomId   String
  room     Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  assetId  String?
  asset    Asset?  @relation(fields: [assetId], references: [id])
  type     String
  assetUrl String?
  posX     Float   @default(0)
  posY     Float   @default(0)
  posZ     Float   @default(0)
  rotY     Float   @default(0)
  scale    Float   @default(1)

  @@index([roomId])
}

model Asset {
  id        String      @id @default(uuid())
  name      String
  type      String      // chair, table, poster, shelf, lamp, etc.
  category  String      // furniture, decoration, anime, manga
  assetUrl  String
  thumbnail String?
  scale     Float       @default(1)
  isPublic  Boolean     @default(true)
  createdAt DateTime    @default(now())
  decors    RoomDecor[]
}

// ─── Events ───────────────────────────────────────────────────────────────────

model Event {
  id           String             @id @default(uuid())
  title        String
  description  String?            @db.Text
  type         String             @default("GENERAL") // QUIZ, FANART, WATCHPARTY, COSPLAY, GENERAL
  startAt      DateTime
  endAt        DateTime?
  clubId       String?
  club         Club?              @relation(fields: [clubId], references: [id])
  creatorId    String
  isPublic     Boolean            @default(true)
  bannerUrl    String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  participants EventParticipant[]
}

model EventParticipant {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  status    String   @default("GOING") // GOING, INTERESTED, NOT_GOING
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

// ─── Fan Content ──────────────────────────────────────────────────────────────

model FanArt {
  id             String   @id @default(uuid())
  authorId       String
  title          String
  description    String?  @db.Text
  images         String[] // S3 URLs
  tags           String[] // anime/manga/character names
  allowDownload  Boolean  @default(false)
  viewCount      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model FanFic {
  id          String         @id @default(uuid())
  authorId    String
  title       String
  summary     String?        @db.Text
  coverUrl    String?
  tags        String[]
  warnings    String[]       // violence, dark, etc.
  language    String         @default("vi")
  status      String         @default("ONGOING") // ONGOING, COMPLETED, HIATUS
  viewCount   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  chapters    FanFicChapter[]
}

model FanFicChapter {
  id        String   @id @default(uuid())
  fanFicId  String
  fanFic    FanFic   @relation(fields: [fanFicId], references: [id], onDelete: Cascade)
  title     String
  content   String   @db.Text
  order     Int      @default(1)
  wordCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fanFicId])
}

model Cosplay {
  id          String   @id @default(uuid())
  authorId    String
  title       String
  description String?  @db.Text
  images      String[]
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── News ─────────────────────────────────────────────────────────────────────

model NewsArticle {
  id          String   @id @default(uuid())
  title       String
  summary     String?  @db.Text
  url         String   @unique
  imageUrl    String?
  source      String   // crunchyroll, ann, etc.
  category    String   @default("ANIME") // ANIME, MANGA, GAME, MERCHANDISE
  publishedAt DateTime
  createdAt   DateTime @default(now())
}

// ─── Reports ──────────────────────────────────────────────────────────────────

model Report {
  id           String   @id @default(uuid())
  reporterId   String
  entityType   String   // POST, COMMENT, USER, FANART, FANFIC
  entityId     String
  reason       String
  description  String?  @db.Text
  status       String   @default("PENDING") // PENDING, RESOLVED, DISMISSED
  resolvedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
}

// ─── Premium & Monetization ───────────────────────────────────────────────────

model PremiumSubscription {
  id        String    @id @default(uuid())
  userId    String    @unique
  plan      String    @default("MONTHLY") // MONTHLY, YEARLY
  status    String    @default("ACTIVE") // ACTIVE, CANCELLED, EXPIRED
  startAt   DateTime  @default(now())
  endAt     DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model CoinTransaction {
  id          String   @id @default(uuid())
  userId      String
  type        String   // PURCHASE, SPEND, DONATE, EARN
  amount      Int
  description String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model CreatorProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  bio         String?  @db.Text
  totalEarned Int      @default(0)
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
