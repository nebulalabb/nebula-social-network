    "generate": "prisma generate --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^16.4.5",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
