{
  "name": "@anime-social/database",
  "version": "0.1.0",
  "private": true,
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "scripts": {
    "migrate": "prisma migrate deploy --schema=prisma/schema.prisma",
    "migrate:dev": "prisma migrate dev --schema=prisma/schema.prisma",
    "seed": "npx prisma db seed",
